---
const currentYear = new Date().getFullYear();
---

<footer
  class="mt-16 mb-10 w-full px-4 opacity-80"
>
  <div
    class="mx-auto flex w-full max-w-4xl flex-col items-center justify-center gap-4 rounded-lg py-4 text-center md:flex-row md:justify-between md:text-left"
  >
    <span class="max-w-full text-sm text-zinc-800/90 dark:text-zinc-200/90"
      >&copy; {currentYear}
      <a href="https://github.com/JABejaranoVela" class="hover:underline"
        >JABejarano</a
      >. Hecho con Astro · Desplegado en VPS Ubuntu con Nginx y GitHub Actions
    </span>
    <ul
      class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm font-medium dark:text-white/90 md:justify-end"
    >
      <li>
        <a href="/#sobre-mi" class="hover:underline">Sobre mí</a>
      </li>
      <li>
        <a
          id="contacto"
          href="mailto:joseantoniobejarano@outlook.es"
          class="hover:underline">Contacto</a
        >
      </li>
    </ul>
  </div>
</footer>
