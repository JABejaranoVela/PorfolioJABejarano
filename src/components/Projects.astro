---
import ProjectTechBadge from "@/components/ProjectTechBadge.astro"
import { projects } from "@/data/projects"
---

<div class="grid gap-8">
  {
    projects.map((project) => (
      <article class="group grid gap-6 rounded-2xl border border-gray-200 bg-white/60 p-5 shadow-sm transition hover:-translate-y-1 hover:shadow-xl dark:border-gray-800 dark:bg-gray-900/50 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] md:p-6">
        {project.image && (
          <div class="overflow-hidden rounded-xl border border-gray-200 bg-gray-100 dark:border-gray-800 dark:bg-gray-950">
            <img
              alt={`Captura de ${project.title}`}
              class="h-56 w-full object-cover object-top transition duration-500 md:group-hover:scale-105"
              loading="lazy"
              src={project.image}
            />
          </div>
        )}

        <div class="flex flex-col">
          <h3 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
            {project.title}
          </h3>

          <div class="mt-3 flex flex-wrap gap-2">
            {project.mainTechnologies.map((technology) => (
              <ProjectTechBadge label={technology} />
            ))}
          </div>

          <p class="mt-4 line-clamp-5 text-pretty leading-7 text-gray-700 dark:text-gray-400">
            {project.shortDescription}
          </p>

          <footer class="mt-6 flex flex-wrap gap-3">
            <a
              href={`/projects/${project.slug}`}
              class="inline-flex items-center rounded-xl border border-gray-300 bg-gray-100 px-4 py-2 text-base font-medium text-gray-800 transition hover:bg-gray-900 hover:text-white dark:border-gray-700 dark:bg-gray-800 dark:text-white dark:hover:bg-gray-100 dark:hover:text-black"
            >
              Ver detalles
            </a>
            {project.demoUrl ? (
              <a
                href={project.demoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center rounded-xl border border-yellow-500 bg-yellow-400 px-4 py-2 text-base font-medium text-gray-950 transition hover:bg-yellow-300"
              >
                Ver demo
              </a>
            ) : (
              project.githubUrl && (
                <a
                  href={project.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center rounded-xl border border-gray-300 bg-gray-100 px-4 py-2 text-base font-medium text-gray-800 transition hover:bg-gray-900 hover:text-white dark:border-gray-700 dark:bg-gray-800 dark:text-white dark:hover:bg-gray-100 dark:hover:text-black"
                >
                  GitHub
                </a>
              )
            )}
          </footer>
        </div>
      </article>
    ))
  }
</div>
