---
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
  {
    title: "Experiencia",
    label: "experiencia",
    url: "/#experiencia",
  },
  {
    title: "Proyectos",
    label: "proyectos",
    url: "/#proyectos",
  },
  {
    title: "Sobre mí",
    label: "sobre-mi",
    url: "/#sobre-mi",
  },
  {
    title: "Contacto",
    label: "contacto",
    url: "mailto:joseantoniobejarano@outlook.es",
  },
];
---

<header
  class="fixed top-0 z-10 flex w-full items-start justify-center px-2 mt-2 sm:px-0"
>
  <div
    data-header-shell
    class="relative flex items-center rounded-full px-1 text-sm font-medium text-gray-600 dark:text-gray-200 sm:px-3"
  >
    <div class="relative sm:hidden">
      <button
        id="mobile-menu-button"
        type="button"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-haspopup="true"
        class="block rounded-full px-3 py-2 transition hover:text-blue-500 dark:hover:text-blue-500"
      >
        Menú
      </button>
    </div>

    <nav
      id="mobile-menu"
      aria-label="Navegación principal"
      class="absolute left-1/2 top-11 hidden w-64 max-w-[calc(100vw-1rem)] -translate-x-1/2 flex-col gap-1 rounded-lg border border-gray-200 bg-white p-2 shadow-lg dark:border-gray-700 dark:bg-gray-900 sm:hidden"
    >
      {
        navItems.map((link) => (
          <a
            class="block rounded-md px-3 py-2 transition hover:bg-gray-100 hover:text-blue-500 dark:hover:bg-gray-800 dark:hover:text-blue-500"
            aria-label={link.label}
            href={link.url}
          >
            {link.title}
          </a>
        ))
      }
    </nav>

    <nav class="hidden items-center sm:flex" aria-label="Navegación principal">
      {
        navItems.map((link) => (
          <a
            class="relative block px-2 py-2 transition hover:text-blue-500 dark:hover:text-blue-500"
            aria-label={link.label}
            href={link.url}
          >
            {link.title}
          </a>
        ))
      }
    </nav>

    <ThemeToggle />
  </div>
</header>

<script>
  const closeMobileMenu = () => {
    const button = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");

    if (!(button instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) {
      return;
    }

    menu.classList.add("hidden");
    menu.classList.remove("flex");
    button.setAttribute("aria-expanded", "false");
  };

  document.addEventListener("click", (event) => {
    const button = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");
    const target = event.target;

    if (
      !(button instanceof HTMLButtonElement) ||
      !(menu instanceof HTMLElement) ||
      !(target instanceof Node)
    ) {
      return;
    }

    if (button.contains(target)) {
      const willOpen = menu.classList.contains("hidden");
      menu.classList.toggle("hidden", !willOpen);
      menu.classList.toggle("flex", willOpen);
      button.setAttribute("aria-expanded", String(willOpen));
      return;
    }

    if (target instanceof Element && target.closest("#mobile-menu a")) {
      closeMobileMenu();
      return;
    }

    if (!menu.contains(target)) {
      closeMobileMenu();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeMobileMenu();
      document.getElementById("mobile-menu-button")?.focus();
    }
  });

  window.addEventListener("resize", () => {
    const button = document.getElementById("mobile-menu-button");

    if (button && getComputedStyle(button).display === "none") {
      closeMobileMenu();
    }
  });

  document.addEventListener("astro:page-load", () => {
    closeMobileMenu();
    document
      .getElementById("theme-toggle-btn")
      ?.addEventListener("click", closeMobileMenu);

    const sections = document.querySelectorAll("section");
    const navItems = document.querySelectorAll("header nav a");

    const callback = (entries: any[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navItems.forEach((item) => {
            if (item.getAttribute("aria-label") == entry.target.id) {
              item.classList.add("text-blue-500");
            } else {
              item.classList.remove("text-blue-500");
            }
          });
        }
      });
    };

    const observer = new IntersectionObserver(callback, {
      root: null,
      rootMargin: "0px",
      threshold: 0.3,
    });

    sections.forEach((section) => {
      observer.observe(section);
    });

    // Cleanup function
    document.onvisibilitychange = () => {
      if (document.visibilityState === "hidden") {
        observer.disconnect();
      } else {
        sections.forEach((section) => {
          observer.observe(section);
        });
      }
    };
  });
</script>

<style>
  [data-header-shell] {
    animation: nav-shadown 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
    @apply dark:bg-gray-800/90 bg-white/50;
  }

  @keyframes nav-shadown {
    0% {
      background-color: transparent;
    }
    to {
      @apply shadow-lg ring-1 backdrop-blur ring-white/10;
    }
  }
</style>
